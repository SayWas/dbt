* text=auto

# Keep Linux deployment scripts/configs in LF to avoid bash parse errors.
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
Dockerfile text eol=lf

# Env files are sourced by shell on Linux.
.env text eol=lf
.env.* text eol=lf

# Project text/code defaults.
*.py text eol=lf
*.sql text eol=lf
*.md text eol=lf
